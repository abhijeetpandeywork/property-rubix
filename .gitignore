# ============================================================
# PropertyRubix — Enterprise .gitignore
# ============================================================

# ── Sensitive / Environment ──────────────────────────────────
.env
.env.*
!.env.example
config/db.local.php
*.key
*.pem
*.p12
*.pfx
secrets/

# ── Database dumps & migrations (local only) ────────────────
*.sql.bak
database/dumps/
database/exports/

# ── Uploads / Media (stored on S3 / CDN in production) ──────
uploads/
!uploads/.gitkeep

# ── PHP / Composer ──────────────────────────────────────────
vendor/
composer.lock          # Only exclude if you don't want lock file committed
*.cache

# ── OS artifacts ────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
[Dd]esktop.ini

# ── IDE / Editor ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.buildpath
.settings/
*.sublime-workspace

# ── Logs ────────────────────────────────────────────────────
*.log
logs/
error_log
php_errorlog

# ── Node (if any frontend build tools) ──────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Debug / test helpers (never go to production) ───────────
debug_form.php
check_admin.php
check_pages.php
reset_admin.php
test_settings.php
migrate_localities.php
seed_*.php

# ── Build artifacts ─────────────────────────────────────────
dist/
build/
.cache/

# ── XAMPP / local server ────────────────────────────────────
.htpasswd
php.ini
