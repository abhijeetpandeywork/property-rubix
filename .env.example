# ── PropertyRubix Environment Configuration ─────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Database
DB_HOST=localhost
DB_NAME=property_rubix
DB_USER=root
DB_PASS=

# Application
APP_ENV=local          # local | staging | production
APP_DEBUG=true
APP_URL=http://localhost/property-rubix/

# Email (SMTP)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@propertyrubix.com

# File Storage
UPLOAD_DRIVER=local    # local | s3
AWS_BUCKET=
AWS_KEY=
AWS_SECRET=
AWS_REGION=ap-south-1

# Analytics / Monitoring
SENTRY_DSN=
GA_TRACKING_ID=
