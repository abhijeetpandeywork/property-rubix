# ── PropertyRubix Environment Configuration ─────────────────────────────────
# Copy this file to .env and fill in your local values
# NEVER commit your .env file to version control!
#
# Quick setup:
#   Windows: copy .env.example .env
#   Mac/Linux: cp .env.example .env

# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=property_rubix
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ── Application ───────────────────────────────────────────────────────────────
# APP_ENV options: local | staging | production
APP_ENV=local
# APP_DEBUG: true shows detailed error messages, false shows generic errors
APP_DEBUG=true

# ── Branding (optional — overrides DB settings) ───────────────────────────────
SITE_NAME=PropertyRubix
SITE_TAGLINE=Find Your Perfect Property

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Use Mailtrap (https://mailtrap.io) for local email testing
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@propertyrubix.com
MAIL_FROM_NAME=PropertyRubix

# ── File Storage ──────────────────────────────────────────────────────────────
# UPLOAD_DRIVER options: local | s3
UPLOAD_DRIVER=local
# Only needed if UPLOAD_DRIVER=s3
AWS_BUCKET=
AWS_KEY=
AWS_SECRET=
AWS_REGION=ap-south-1

# ── Analytics / Monitoring (optional) ─────────────────────────────────────────
SENTRY_DSN=
GA_TRACKING_ID=
GOOGLE_MAPS_KEY=
